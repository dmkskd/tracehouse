{
  "name": "tracehouse",
  "version": "0.17.1",
  "private": true,
  "workspaces": [
    "packages/*",
    "frontend",
    "grafana-app-plugin"
  ],
  "scripts": {
    "deps:install": "npm install --legacy-peer-deps",
    "deps:install:workspaces": "npm install --legacy-peer-deps --workspaces --include-workspace-root",
    "build": "npm run build --workspace packages/core && npm run build --workspace packages/ui-shared && npm run build --workspace grafana-app-plugin && rm -rf dist && cp -R grafana-app-plugin/dist dist",
    "sign": "cd grafana-app-plugin && npx @grafana/sign-plugin@latest",
    "test": "npm run test --workspaces --if-present",
    "test:report": "npm run test --workspaces --if-present -- --reporter=verbose",
    "test:html": "npm run test --workspaces --if-present",
    "test:tag": "npm run test --workspaces --if-present -- --tags-filter",
    "test:list-tags": "npm run test --workspaces --if-present -- --list-tags",
    "security:scan": "semgrep --config auto packages/ frontend/src/"
  },
  "overrides": {
    "three": "^0.182.0",
    "@types/three": "^0.182.0",
    "serialize-javascript": "7.0.4",
    "dompurify": "3.4.8",
    "immutable": "5.1.5"
  },
  "dependencies": {
    "react-is": "^19.1.0"
  }
}
