# TraceHouse Frontend Configuration
# Copy this file to .env and modify as needed

# Backend API URL
VITE_API_BASE_URL=http://localhost:8000

# WebSocket URL for real-time updates
VITE_WS_BASE_URL=ws://localhost:8000

# Default polling interval in milliseconds
VITE_DEFAULT_POLL_INTERVAL=5000

# Enable debug mode (shows additional logging in console)
VITE_DEBUG=false

# 3D Visualization Settings
# Maximum number of elements to render in performance mode
VITE_3D_MAX_ELEMENTS=1000

# Enable animations (can be disabled for better performance)
VITE_3D_ENABLE_ANIMATIONS=true

# Default color scheme for parts visualization: 'size' | 'age' | 'level'
VITE_3D_DEFAULT_COLOR_SCHEME=size

# Warning Thresholds (for UI highlighting)
VITE_CPU_WARNING_THRESHOLD=80
VITE_MEMORY_WARNING_THRESHOLD=85
VITE_QUERY_DURATION_WARNING_SECONDS=60
VITE_PARTS_COUNT_WARNING=300

# Bundled proxy mode (set to "true" in Docker builds)
# When enabled, the app always uses the co-located proxy at /proxy
# and hides the proxy configuration from the connection form.
VITE_BUNDLED_PROXY=false
