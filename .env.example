# TraceHouse - Root Environment Configuration
# This file provides an overview of all configuration options.
# Copy to .env and uncomment/edit the values you need.

# ============================================
# ClickHouse Connection (used by data-utils CLI tools)
# ============================================
# These are read by tracehouse-generate, tracehouse-queries, tracehouse-mutations, etc.
# They can also be overridden with CLI flags (--host, --port, etc.).

CH_HOST=localhost
CH_PORT=9000
CH_USER=default
CH_PASSWORD=
CH_SECURE=false

# Point scripts at a different .env file (or use --env-file <path>):
# CH_ENV_FILE=/path/to/my/.env

# Skip confirmation prompts (or use -y / --assume-yes):
# CH_ASSUME_YES=true

# ============================================
# Data Generation (tracehouse-generate)
# ============================================
CH_GEN_ROWS=100_000_000           # Total rows per table
CH_GEN_PARTITIONS=3            # Number of partitions/months to spread data across
CH_GEN_BATCH_SIZE=50_0000       # Rows per INSERT batch
CH_GEN_DROP=false              # Drop existing tables before creating
CH_GEN_PARALLELISM=0           # 0 = all tables in parallel, N = max N concurrent
CH_GEN_THROTTLE_MIN=0          # Min delay in seconds between batches (0 = no throttle)
CH_GEN_THROTTLE_MAX=0          # Max delay in seconds between batches (0 = no throttle)
CH_GEN_DATASET=                # blank = all datasets, or: synthetic, taxi, uk, web
#CH_GEN_DATASET=                # blank = all datasets, or: synthetic, taxi, uk, web

# ============================================
# Query Runner (tracehouse-queries)
# ============================================
CH_QUERY_SLOW_INTERVAL=1.0
CH_QUERY_FAST_INTERVAL=10.0
CH_QUERY_S3_INTERVAL=30.0
CH_QUERY_PK_INTERVAL=5.0
CH_QUERY_SLOW_WORKERS=5
CH_QUERY_FAST_WORKERS=1
CH_QUERY_S3_WORKERS=2
CH_QUERY_PK_WORKERS=2
CH_QUERY_JOIN_INTERVAL=3.0
CH_QUERY_JOIN_WORKERS=2
CH_QUERY_SETTINGS_INTERVAL=5.0
CH_QUERY_SETTINGS_WORKERS=1

# ============================================
# Mutations (tracehouse-mutations)
# ============================================
CH_MUTATION_COUNT=10             # Number of mutations to run
CH_MUTATION_INTERVAL=3.0         # Seconds between mutations
CH_MUTATION_DATABASE=synthetic_data
CH_MUTATION_TABLE=events
CH_MUTATION_TYPE=
# CH_MUTATION_TYPE=                # blank = all types, or one of:
#   lightweight_delete             #   DELETE FROM (mask-based, no part rewrite)
#   lightweight_update             #   UPDATE SET (patch-based, no full part rewrite) [beta, unstable on CH 26.1]
#   heavy_delete                   #   ALTER TABLE DELETE (rewrites parts)
#   heavy_update                   #   ALTER TABLE UPDATE (rewrites parts)
#   lightweight                    #   both lightweight_delete + lightweight_update
#   heavy                          #   both heavy_delete + heavy_update
#   delete                         #   both lightweight_delete + heavy_delete
#   update                         #   both lightweight_update + heavy_update
# CH_MUTATION_SYNC=async           # async = fire-and-forget (mutations_sync=0), returns immediately
                                   #   sync  = wait for mutation to complete on this replica (mutations_sync=1)
                                   #   Applies to all mutation types including DELETE FROM which is sync by default

# ============================================
# Multi-User Simulation (all tools)
# ============================================
# Create temporary ClickHouse users so queries, inserts, and mutations appear
# under different usernames in system tables (query_log, processes, etc.).
# Useful for testing per-user dashboards and spotting "noisy neighbor" patterns.
#
# CH_USERS=0                       # Number of test users (1-10). 0 = use default user only.
                                   #   Users are named th_alice, th_bob, th_charlie, …
                                   #   Each run generates fresh random passwords.
                                   #   On exit, users are locked with HOST NONE (no one can connect).
# CH_USER_SKEW=0                   # Controls how unevenly work is distributed across users:
                                   #   0   = equal (flat distribution)
                                   #   1   = Zipf (th_alice ~55%, th_bob ~27%, th_charlie ~18%)
                                   #   2+  = very skewed (alice dominates)
                                   #   Useful for creating a clear "noisy user" in demos.
