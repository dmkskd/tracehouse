# TraceHouse - Root Environment Configuration
# This file provides an overview of all configuration options.
# Copy to .env and uncomment/edit the values you need.

# ============================================
# ClickHouse Connection (used by infra/scripts/)
# ============================================
# These are read by setup_test_data.py, run_mutations.py, and run_queries.py.
# They can also be overridden with CLI flags (--host, --port, etc.).

CH_HOST=localhost
CH_PORT=9000
CH_USER=default
CH_PASSWORD=
CH_SECURE=false

# Point scripts at a different .env file (or use --env-file <path>):
# CH_ENV_FILE=/path/to/my/.env

# ============================================
# Data Loading (setup_test_data.py)
# ============================================
# CH_LOAD_ROWS=10000000           # Total rows per table
# CH_LOAD_PARTITIONS=3            # Number of partitions/months to spread data across
# CH_LOAD_BATCH_SIZE=500000       # Rows per INSERT batch
# CH_LOAD_DROP=false              # Drop existing tables before creating
# CH_LOAD_PARALLELISM=0           # 0 = all tables in parallel, N = max N concurrent
# CH_LOAD_THROTTLE_MIN=0          # Min delay in seconds between batches (0 = no throttle)
# CH_LOAD_THROTTLE_MAX=0          # Max delay in seconds between batches (0 = no throttle)
# CH_LOAD_DATASET=                # blank = all datasets, or: synthetic, taxi, uk, web

# ============================================
# Query Runner (run_queries.py)
# ============================================
# CH_QUERY_SLOW_INTERVAL=1.0
# CH_QUERY_FAST_INTERVAL=10.0
# CH_QUERY_S3_INTERVAL=30.0
# CH_QUERY_PK_INTERVAL=5.0
# CH_QUERY_SLOW_WORKERS=5
# CH_QUERY_FAST_WORKERS=1
# CH_QUERY_S3_WORKERS=2
# CH_QUERY_PK_WORKERS=2
# CH_QUERY_JOIN_INTERVAL=3.0
# CH_QUERY_JOIN_WORKERS=2
# CH_QUERY_SETTINGS_INTERVAL=5.0
# CH_QUERY_SETTINGS_WORKERS=1

# ============================================
# Mutations (run_mutations.py)
# ============================================
# CH_MUTATION_COUNT=10             # Number of mutations to run
# CH_MUTATION_INTERVAL=3.0         # Seconds between mutations
# CH_MUTATION_DATABASE=synthetic_data
# CH_MUTATION_TABLE=events
# CH_MUTATION_TYPE=                # blank = all types, or one of:
#   lightweight_delete             #   DELETE FROM (mask-based, no part rewrite)
#   lightweight_update             #   UPDATE SET (patch-based, no full part rewrite) [beta, unstable on CH 26.1]
#   heavy_delete                   #   ALTER TABLE DELETE (rewrites parts)
#   heavy_update                   #   ALTER TABLE UPDATE (rewrites parts)
#   lightweight                    #   both lightweight_delete + lightweight_update
#   heavy                          #   both heavy_delete + heavy_update
#   delete                         #   both lightweight_delete + heavy_delete
#   update                         #   both lightweight_update + heavy_update
# CH_MUTATION_SYNC=async           # async = fire-and-forget (mutations_sync=0), returns immediately
                                   #   sync  = wait for mutation to complete on this replica (mutations_sync=1)
                                   #   Applies to all mutation types including DELETE FROM which is sync by default
