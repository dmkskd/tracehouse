{
  "name": "@tracehouse/proxy",
  "version": "0.1.0",
  "type": "module",
  "description": "Lightweight local proxy to bypass CORS when connecting to remote ClickHouse servers",
  "main": "dist/index.js",
  "bin": {
    "tracehouse-proxy": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "dev": "node --loader ts-node/esm src/index.ts",
    "start": "node dist/index.js",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "http-proxy-middleware": "^3.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "typescript": "~5.8.0",
    "vitest": "^4.1.2"
  }
}
