# TraceHouse Demo — Caddy reverse proxy / load balancer
#
# Exposes:
#   :80    — Frontend (HTTP)
#   :8443  — ClickHouse HTTPS (self-signed TLS, load-balanced across 4 nodes)
#   :8123  — ClickHouse HTTP  (temporary, remove when ready)
#   :3000  — Grafana
#
# For automatic Let's Encrypt TLS, replace `:80` with your domain:
#   demo.yourdomain.com {
#       reverse_proxy frontend:8990
#   }

{
	local_certs
	log {
		output stdout
		format json
		level INFO
	}
}

# Frontend — serves the TracehHouse UI + CORS proxy
http://:80 {
	log
	reverse_proxy frontend:8990
}

# ClickHouse HTTPS — TLS-terminated, load-balanced
:8443 {
	log
	# Strip PII — prevent real client IPs and browser fingerprints from leaking into query_log
	request_header -X-Forwarded-For
	request_header -X-Forwarded-Proto
	request_header -X-Real-Ip
	request_header User-Agent "TraceHouse"
	reverse_proxy ch-s1r1:8123 ch-s1r2:8123 ch-s2r1:8123 ch-s2r2:8123 {
		lb_policy round_robin
		health_uri /ping
		health_interval 10s
	}
}

# ClickHouse HTTP — plain HTTP, load-balanced (temporary)
http://:8123 {
	log
	# Strip PII — prevent real client IPs and browser fingerprints from leaking into query_log
	request_header -X-Forwarded-For
	request_header -X-Forwarded-Proto
	request_header -X-Real-Ip
	request_header User-Agent "TraceHouse"
	reverse_proxy ch-s1r1:8123 ch-s1r2:8123 ch-s2r1:8123 ch-s2r2:8123 {
		lb_policy round_robin
		health_uri /ping
		health_interval 10s
	}
}

# Grafana
http://:3000 {
	log
	redir / /a/dmkskd-tracehouse-app/overview 302
	reverse_proxy grafana:3000
}
