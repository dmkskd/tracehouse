<clickhouse>
  <users>
    <!-- Test users for the demo workload generator.
         All share the default password and have full privileges for data generation.
         Queries from these users show up with distinct names in query_log. -->
    <th_alice>
      <password from_env="TH_PASSWORD"/>
      <profile>workload_profile</profile>
      <networks><ip>::/0</ip></networks>
      <quota>default</quota>
      <grants>
        <query>GRANT ALL ON *.*</query>
      </grants>
    </th_alice>
    <th_bob>
      <password from_env="TH_PASSWORD"/>
      <profile>workload_profile</profile>
      <networks><ip>::/0</ip></networks>
      <quota>default</quota>
      <grants>
        <query>GRANT ALL ON *.*</query>
      </grants>
    </th_bob>
    <th_carol>
      <password from_env="TH_PASSWORD"/>
      <profile>workload_profile</profile>
      <networks><ip>::/0</ip></networks>
      <quota>default</quota>
      <grants>
        <query>GRANT ALL ON *.*</query>
      </grants>
    </th_carol>
    <th_dave>
      <password from_env="TH_PASSWORD"/>
      <profile>workload_profile</profile>
      <networks><ip>::/0</ip></networks>
      <quota>default</quota>
      <grants>
        <query>GRANT ALL ON *.*</query>
      </grants>
    </th_dave>
    <th_eve>
      <password from_env="TH_PASSWORD"/>
      <profile>workload_profile</profile>
      <networks><ip>::/0</ip></networks>
      <quota>default</quota>
      <grants>
        <query>GRANT ALL ON *.*</query>
      </grants>
    </th_eve>
  </users>

  <profiles>
    <workload_profile>
      <enable_parallel_replicas>1</enable_parallel_replicas>
      <max_parallel_replicas>2</max_parallel_replicas>
      <cluster_for_parallel_replicas>tracehouse</cluster_for_parallel_replicas>
      <parallel_replicas_min_number_of_rows_per_replica>100000</parallel_replicas_min_number_of_rows_per_replica>
    </workload_profile>
  </profiles>
</clickhouse>
